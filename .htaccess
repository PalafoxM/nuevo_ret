Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # En local exponemos el contenido de public/ sin cambiar la URL visible.
    RewriteCond %{REQUEST_URI} !^/ret/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    RewriteCond %{REQUEST_URI} !^/ret/public/
    RewriteRule ^$ public/ [L]
</IfModule>
